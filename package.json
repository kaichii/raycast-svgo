{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "test",
  "title": "svgo",
  "description": "using svgo in raycast",
  "icon": "command-icon.png",
  "author": "kaichi",
  "license": "MIT",
  "commands": [
    {
      "name": "optimize",
      "title": "Optimize",
      "description": "using svgo in raycast",
      "mode": "no-view"
    },
    {
      "name": "config",
      "title": "Config",
      "description": "svgo configuration",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.38.2",
    "@raycast/utils": "^1.0.7",
    "svgo": "^2.8.0"
  },
  "devDependencies": {
    "@types/svgo": "^2.6.3",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "prettier": "^2.5.1",
    "typescript": "^4.4.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  }
}
